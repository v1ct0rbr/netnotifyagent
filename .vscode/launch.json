{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "java",
            "name": "NetnotifyagentLauncher",
            "request": "launch",
            "mainClass": "br.gov.pb.der.netnotifyagent.NetnotifyagentLauncher",
            "projectName": "netnotifyagent",
            "cwd": "${workspaceFolder}",
            "vmArgs": "--module-path \"${workspaceFolder}/target/libs\" --add-modules javafx.controls,javafx.web,javafx.swing,javafx.fxml,javafx.media"
        }
    ]
}