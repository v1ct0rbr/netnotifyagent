@echo off
setlocal EnableDelayedExpansion

set "SHOULD_PAUSE=0"
for %%A in (%*) do (
    if /I "%%~A"=="/pause" set "SHOULD_PAUSE=1"
)

call :main
exit /b %errorlevel%

:main

rem entrar no diretório do script
cd /d "%~dp0"
set "BASE_DIR=%CD%"
set "JAR_FILE="
for %%F in ("%BASE_DIR%\netnotifyagent-*.jar") do (
    set "JAR_FILE=%%~fF"
    goto :afterJarSearch
)
:afterJarSearch
set "LIBS_DIR=%BASE_DIR%\libs"
set "SETTINGS_FILE=%BASE_DIR%\resources\settings.properties"
set "RESOLVED_JAVA_HOME="

rem tentar localizar java via settings.properties (java.executable/java.home)
set "JAVA_EXE="
set "CFG_JAVA_EXE="
set "CFG_JAVA_HOME="
if exist "%SETTINGS_FILE%" (
    for /f "usebackq eol=# tokens=1,* delims==" %%A in ("%SETTINGS_FILE%") do (
        set "KEY=%%~A"
        set "VAL=%%~B"
        if /I "!KEY!"=="java.executable" set "CFG_JAVA_EXE=!VAL!"
        if /I "!KEY!"=="java.home" set "CFG_JAVA_HOME=!VAL!"
    )
    rem remover todas as aspas (nao apenas backslash-aspas)
    if defined CFG_JAVA_EXE set "CFG_JAVA_EXE=!CFG_JAVA_EXE:"=!"
    if defined CFG_JAVA_HOME set "CFG_JAVA_HOME=!CFG_JAVA_HOME:"=!"
    rem normalizar separadores e remover barra final
    if defined CFG_JAVA_HOME (
        set "CFG_JAVA_HOME=!CFG_JAVA_HOME:/=\!"
        if "!CFG_JAVA_HOME:~-1!"=="\" set "CFG_JAVA_HOME=!CFG_JAVA_HOME:~0,-1!"
        rem se o usuario informou o executavel em vez do diretorio, tratar como java.executable
        if /I "!CFG_JAVA_HOME:~-8!"=="java.exe" (
            if not defined CFG_JAVA_EXE set "CFG_JAVA_EXE=!CFG_JAVA_HOME!"
            set "CFG_JAVA_HOME="
        ) else if /I "!CFG_JAVA_HOME:~-9!"=="javaw.exe" (
            if not defined CFG_JAVA_EXE set "CFG_JAVA_EXE=!CFG_JAVA_HOME!"
            set "CFG_JAVA_HOME="
        )
    )
    if defined CFG_JAVA_EXE call :try_java_exe "!CFG_JAVA_EXE!"
    if not defined JAVA_EXE if defined CFG_JAVA_HOME call :try_java_home "!CFG_JAVA_HOME!"
)

if not defined JAVA_EXE call :find_java_in_system

if defined JAVA_EXE call :persist_java_home
if defined JAVA_EXE goto :execute

echo [ERRO] Java nao encontrado. Defina JAVA_HOME ou coloque java no PATH.
if "!SHOULD_PAUSE!"=="1" pause
exit /b 1

:execute
if not defined JAR_FILE if not exist "!JAR_FILE!" (
    echo [ERRO] Arquivo principal nao encontrado
    echo Procurando: !JAR_FILE!
    echo.
    echo Certifique-se de que todos os arquivos foram extraidos corretamente.
    if "!SHOULD_PAUSE!"=="1" pause
    exit /b 1
)

if not exist "!LIBS_DIR!" (
    echo [ERRO] Diretorio libs nao encontrado
    echo Procurando: !LIBS_DIR!
    if "!SHOULD_PAUSE!"=="1" pause
    exit /b 1
)

rem executar sem usar wildcards na variavel
REM Verificar versao do Java (necessario Java 21+)
REM javaw.exe pode nao imprimir versao; usar java.exe para a verificacao
set "JAVA_CHECK_EXE="
if /I "!JAVA_EXE:~-9!"=="javaw.exe" (
    set "JAVA_CHECK_EXE=!JAVA_EXE:javaw.exe=java.exe!"
) else (
    set "JAVA_CHECK_EXE=!JAVA_EXE!"
)
if not exist "!JAVA_CHECK_EXE!" set "JAVA_CHECK_EXE=!JAVA_EXE!"

set "JAVA_MAJOR="
set "_JCEXE=!JAVA_CHECK_EXE!"
for /f "usebackq" %%v in (`powershell -NoProfile -Command "try{$i=[System.Diagnostics.ProcessStartInfo]::new('%_JCEXE%','-version');$i.RedirectStandardError=$true;$i.UseShellExecute=$false;$p=[System.Diagnostics.Process]::Start($i);$o=$p.StandardError.ReadToEnd();$p.WaitForExit();if($o-match('version\s+'+[char]34+'(\d+)')){$Matches[1]}else{''}}catch{''}"`) do set "JAVA_MAJOR=%%v"
if "!JAVA_MAJOR!"=="" (
    echo Aviso: Nao foi possivel verificar versao do Java. Prosseguindo...
    goto :run
)
if !JAVA_MAJOR! LSS 21 (
    echo Erro: Java 21+ e necessario. Versao atual: !JAVA_MAJOR!
    if "!SHOULD_PAUSE!"=="1" pause
    exit /b 1
)
:run
start "" "!JAVA_EXE!" --module-path "!LIBS_DIR!" --add-modules javafx.controls,javafx.web,javafx.swing,javafx.fxml,javafx.media -cp "!JAR_FILE!;!LIBS_DIR!\*" br.gov.pb.der.netnotifyagent.NetnotifyagentLauncher

exit /b 0

:find_java_in_system
call :check_registry "SOFTWARE\JavaSoft\JDK"
if defined JAVA_EXE exit /b 0

call :check_registry "SOFTWARE\JavaSoft\Java Development Kit"
if defined JAVA_EXE exit /b 0

call :check_registry_wow64
if defined JAVA_EXE exit /b 0

if defined JAVA_HOME call :try_java_home "%JAVA_HOME%"
if defined JAVA_EXE exit /b 0

for /f "delims=" %%P in ('where javaw.exe 2^>nul') do (
    if not defined JAVA_EXE call :try_java_exe "%%P"
)
if defined JAVA_EXE exit /b 0

for /f "delims=" %%P in ('where java.exe 2^>nul') do (
    if not defined JAVA_EXE call :try_java_exe "%%P"
)
exit /b 0

:try_java_home
set "_TRY_JAVA_HOME=%~1"
if "%_TRY_JAVA_HOME%"=="" exit /b 0
if "%_TRY_JAVA_HOME:~-1%"=="\" set "_TRY_JAVA_HOME=%_TRY_JAVA_HOME:~0,-1%"

if exist "%_TRY_JAVA_HOME%\bin\javaw.exe" call :try_java_exe "%_TRY_JAVA_HOME%\bin\javaw.exe"
if defined JAVA_EXE exit /b 0

if exist "%_TRY_JAVA_HOME%\bin\java.exe" call :try_java_exe "%_TRY_JAVA_HOME%\bin\java.exe"
exit /b 0

:try_java_exe
set "_TRY_JAVA_EXE=%~1"
if "%_TRY_JAVA_EXE%"=="" exit /b 0
if not exist "%_TRY_JAVA_EXE%" exit /b 0

call :check_version "%_TRY_JAVA_EXE%" _TRY_JAVA_MAJOR
if not defined _TRY_JAVA_MAJOR exit /b 0
if %_TRY_JAVA_MAJOR% LSS 21 exit /b 0

set "JAVA_EXE=%_TRY_JAVA_EXE%"
call :derive_java_home "%_TRY_JAVA_EXE%" RESOLVED_JAVA_HOME
exit /b 0

:derive_java_home
set "%~2="
for %%D in ("%~dp1..") do set "%~2=%%~fD"
if defined %~2 (
    call set "_DERIVED_VALUE=%%%~2%%"
    if "!_DERIVED_VALUE:~-1!"=="\" set "%~2=!_DERIVED_VALUE:~0,-1!"
)
exit /b 0

:persist_java_home
if not defined SETTINGS_FILE exit /b 0
if not exist "%SETTINGS_FILE%" exit /b 0
if not defined RESOLVED_JAVA_HOME exit /b 0

if /I "%CFG_JAVA_HOME%"=="%RESOLVED_JAVA_HOME%" exit /b 0

set "PS_SCRIPT=%TEMP%\_run_bat_fix_java_home_%RANDOM%.ps1"
(
    echo $file = '%SETTINGS_FILE%'
    echo $javaHome = '%RESOLVED_JAVA_HOME%'
    echo $lines = Get-Content -LiteralPath $file -Encoding UTF8
    echo $found = $false
    echo $result = foreach ^($line in $lines^) {
    echo     $trimmed = $line.Trim^(
    echo     ^)
    echo     if ^($trimmed -match '^#?\s*java\.home\s*='^) {
    echo         "java.home=$javaHome"
    echo         $found = $true
    echo     ^} else {
    echo         $line
    echo     ^}
    echo ^}
    echo if ^(-not $found^) { $result += "java.home=$javaHome" }
    echo $result ^| Set-Content -LiteralPath $file -Encoding UTF8
) > "%PS_SCRIPT%"

powershell -ExecutionPolicy Bypass -File "%PS_SCRIPT%" >nul 2>&1
del "%PS_SCRIPT%" 2>nul
exit /b 0

:check_registry
set "_REGKEY=%~1"
set "_REGVER="
for /f "tokens=3*" %%A in ('reg query "HKLM\%_REGKEY%" /v CurrentVersion 2^>nul') do set "_REGVER=%%A"
if not defined _REGVER exit /b 0

set "_REGHOME="
for /f "tokens=3*" %%A in ('reg query "HKLM\%_REGKEY%\%_REGVER%" /v JavaHome 2^>nul') do set "_REGHOME=%%A %%B"
if not defined _REGHOME exit /b 0
if "%_REGHOME:~-1%"==" " set "_REGHOME=%_REGHOME:~0,-1%"

call :try_java_home "%_REGHOME%"
exit /b 0

:check_registry_wow64
set "_WOW_VER="
for /f "tokens=3*" %%A in ('reg query "HKLM\SOFTWARE\WOW6432Node\JavaSoft\JDK" /v CurrentVersion 2^>nul') do set "_WOW_VER=%%A"
if not defined _WOW_VER exit /b 0

set "_REGHOME32="
for /f "tokens=3*" %%A in ('reg query "HKLM\SOFTWARE\WOW6432Node\JavaSoft\JDK\%_WOW_VER%" /v JavaHome 2^>nul') do set "_REGHOME32=%%A %%B"
if not defined _REGHOME32 exit /b 0
if "%_REGHOME32:~-1%"==" " set "_REGHOME32=%_REGHOME32:~0,-1%"

call :try_java_home "%_REGHOME32%"
exit /b 0
